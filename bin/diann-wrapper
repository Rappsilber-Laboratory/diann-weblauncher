#!/bin/bash

# Find the real diann binary
DIANN_BIN=$(find /opt/diann -maxdepth 2 -name "diann-linux" | head -n 1)
if [ -z "$DIANN_BIN" ]; then
    echo "Error: DIA-NN binary (diann-linux) not found in /opt/diann or PATH" >&2
    exit 1
fi

ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --F)
      DIR="$2"
      if [[ ! -d "$DIR" ]]; then
        echo "Error: $DIR is not a directory" >&2
        exit 1
      fi
      shopt -s nullglob
      while IFS= read -r f; do
        ARGS+=(--f "$f")
      done < <(ls -d "$DIR"/*.d 2>/dev/null | sort -V)
      while IFS= read -r f; do
        ARGS+=(--f "$f")
      done < <(ls -d "$DIR"/*.raw 2>/dev/null | sort -V)
      shopt -u nullglob
      shift 2
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

echo "Executing: $DIANN_BIN ${ARGS[@]}"
exec "$DIANN_BIN" "${ARGS[@]}"
