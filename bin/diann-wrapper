#!/bin/bash

# Find the real diann binary
DIANN_BIN=$(find /opt/diann -maxdepth 2 -name "diann-linux" | head -n 1)
if [ -z "$DIANN_BIN" ]; then
    echo "Error: DIA-NN binary (diann-linux) not found in /opt/diann or PATH" >&2
    exit 1
fi

ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --F)
      DIR="$2"
      if [[ ! -d "$DIR" ]]; then
        echo "Error: $DIR is not a directory" >&2
        exit 1
      fi
      
      # Use nullglob to avoid literal glob strings when no match
      shopt -s nullglob
      # Create an array of files
      FILES=("$DIR"/*.d "$DIR"/*.raw)
      shopt -u nullglob
      
      if [ ${#FILES[@]} -eq 0 ]; then
        echo "Warning: No .d or .raw files found in $DIR" >&2
      else
        # Process files one by one to handle spaces correctly
        # We sort them naturally using sort -V
        while IFS= read -r -d '' f; do
            ARGS+=(--f "$f")
        done < <(printf '%s\0' "${FILES[@]}" | sort -zV)
      fi
      
      shift 2
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

echo "Executing: $DIANN_BIN ${ARGS[@]}"
exec "$DIANN_BIN" "${ARGS[@]}"
